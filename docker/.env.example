# =====================================================
# ARDMS Docker Environment Variables
# Copy this to .env and update values
# =====================================================

# MySQL
MYSQL_ROOT_PASSWORD=root_secure_password_change_me
MYSQL_DATABASE=ardms_db
MYSQL_USER=ardms_user
MYSQL_PASSWORD=ardms_secure_pass_change_me
MYSQL_PORT=3306

# Application
APP_PORT=8080
ADMINER_PORT=8081

# JWT (MUST change in production - use 256+ bit random string)
JWT_SECRET=ardms-super-secret-jwt-key-must-be-at-least-256-bits-long-for-hs256-algorithm
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
