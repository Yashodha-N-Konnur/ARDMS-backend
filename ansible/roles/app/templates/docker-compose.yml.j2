version: '3.8'
services:
  ardms-backend:
    image: {{ ardms_docker_image }}:{{ app_image_tag | default('latest') }}
    container_name: ardms-backend
    restart: unless-stopped
    env_file:
      - .env
    ports:
      - "{{ ardms_app_port }}:8080"
    volumes:
      - {{ ardms_logs_dir }}:/app/logs
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider",
             "http://localhost:8080/api/actuator/health"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 90s
